# Google Places API (Text Search / Place Details, New) を使う場合に設定する。
# 未設定の場合は目的地検索がダミーデータ(渋谷ヒカリエ・新宿NSビルの2件)にフォールバックする。
GOOGLE_PLACES_API_KEY=

# Gemini API。fixtureに無い駅の号車・改札・出口の下書き生成、および
# fixtureに無い駅間の鉄道経路(Google Search Groundingで検索の裏付けを取得)に使う。
# 未設定の場合はfixtureの3駅のみで動作する(confidence: lowの下書き生成は行われない)。
#
# 現在地からの最寄り駅検索自体はHeartRails Express API(キー不要・無料)を
# オンデマンド呼び出しするためこのキーを直接は使わないが、実装上はこのキーの
# 設定有無で有効/無効を切り替えている(未設定時はfixtureの3駅のみを返す)。
GEMINI_API_KEY=

# 管理画面(/admin/feedback)へのアクセスを許可するメールアドレス(カンマ区切り)。
ADMIN_EMAILS=

# 到着駅の改札・出口AI検索に、目的地施設名(destinationHint)を検索ヒントとして
# 含めるかどうかのキルスイッチ。"1"のときのみ有効(既定OFF)。
# 本番同一構成でのE2E検証で、hint有りの方が駅全体検索より劣化する
# (改札・出口が「確認できません」になる)ことを確認したため、
# destination-hint-verification.test.ts の検証ゲート(hint有り≧hint無しを
# 実APIで確認)を通過するまではデフォルトOFFで運用する。
DESTINATION_HINT_ENABLED=

# Langfuse(Vercel AI SDKのtelemetry経由でLLM呼び出しを観測する)。
# src/instrumentation.ts で @langfuse/otel の LangfuseSpanProcessor と
# @langfuse/vercel-ai-sdk の registerTelemetry() を配線済み。
# 未設定の場合、LangfuseSpanProcessorは送信先を持たないだけでエラーにはならず、
# テレメトリはどこにも送信されない(実質no-opのまま動作する)。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# 正式名はLANGFUSE_BASE_URL(LANGFUSE_BASEURLは後方互換のレガシーエイリアス)。
# 未設定時の既定値は https://cloud.langfuse.com 。セルフホストの場合はそのURLを指定する。
LANGFUSE_BASE_URL=

# Turso (libSQL) 永続ストア。AIキャッシュ(改札・出口・号車・経路)の保存先。
# 両方設定されている場合のみTursoを使い、未設定時はローカルの data/*.json に
# フォールバックする(ローカル開発では未設定で可)。本番(Vercel)では必ず設定する
# こと(未設定だと読み取り専用FSでキャッシュが毎回失われ、AI再生成コストが発生する)。
# スキーマは src/lib/store/turso-schema.sql を turso db shell で適用する。
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
